# Environment Variables Configuration
# Copy this file to .env and fill in the actual values

# ===========================================
# JWT Authentication
# ===========================================
# Generate strong secrets (minimum 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
# JWT_REFRESH_SECRET is recommended for production (REQUIRED for refresh endpoint)
# If not set, JWT_SECRET will be used as fallback (not recommended for production)
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long

# ===========================================
# Database Configuration
# ===========================================
# SQLite database file path (relative to project root)
DATABASE_PATH=database.sqlite

# ===========================================
# Payment Gateway Configuration
# ===========================================
# Atlos payment gateway secret
ATLOS_API_SECRET=your-atlos-api-secret-key

# ===========================================
# Email Configuration (SMTP)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# ===========================================
# Security & Verification
# ===========================================
# Admin API key (REQUIRED - generate strong secret, minimum 32 characters)
# You can use: openssl rand -base64 32
ADMIN_API_KEY=your-admin-api-key-minimum-32-characters-long

# Cloudflare Turnstile keys
TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Revalidation secret for ISR
REVALIDATE_SECRET=your-revalidation-secret-key

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ===========================================
# File Upload Configuration
# ===========================================
# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4,video/webm

# Upload directory path
UPLOAD_DIR=public/uploads

# ===========================================
# Rate Limiting Configuration
# ===========================================
# Enable/disable rate limiting
RATE_LIMITING_ENABLED=true

# Redis URL for production rate limiting (optional)
# REDIS_URL=redis://localhost:6379

# ===========================================
# Logging Configuration
# ===========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Log file directory
LOG_DIR=logs

# ===========================================
# Application Configuration
# ===========================================
# Application environment
NODE_ENV=development

# Application port
PORT=3000

# Application URL (for generating absolute URLs)
APP_URL=http://localhost:3000

# ===========================================
# Next.js Configuration
# ===========================================
# Public API URL (used by frontend)
NEXT_PUBLIC_API_URL=http://localhost:3000

# ===========================================
# Development Tools
# ===========================================
# Enable debug mode
DEBUG=false

# Enable API documentation
API_DOCS_ENABLED=false

# ===========================================
# Security Headers
# ===========================================
# Content Security Policy
CSP_REPORT_URI=https://yourdomain.com/csp-report

# HSTS max age in seconds
HSTS_MAX_AGE=31536000

# ===========================================
# Monitoring & Analytics
# ===========================================
# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# Google Analytics ID (optional)
# GA_TRACKING_ID=GA-XXXXXXXXX

# ===========================================
# Backup Configuration
# ===========================================
# Backup directory
BACKUP_DIR=backups

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ===========================================
# Cache Configuration
# ===========================================
# Enable caching
CACHE_ENABLED=true

# Cache TTL in seconds
CACHE_TTL=300

# ===========================================
# Testing Configuration
# ===========================================
# Test database path
TEST_DATABASE_PATH=test-database.sqlite

# Test environment flag
NODE_ENV_TEST=test

